# ============================================================================
# CyberVerse Environment Configuration
# Copy this file to .env and fill in the actual values
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_USER=cyberverse
DB_PASSWORD=change_this_secure_password
DB_NAME=cyberverse
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://cyberverse:change_this_secure_password@postgres:5432/cyberverse

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CyberVerse
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# ============================================================================
# BACKEND SETTINGS
# ============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000
BACKEND_CORS_CREDENTIALS=true
BACKEND_CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
BACKEND_CORS_HEADERS=Content-Type,Authorization

# ============================================================================
# JWT TOKEN SETTINGS
# ============================================================================
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# EMAIL CONFIGURATION (للبريد الإلكتروني والتحقق)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@cyberverse.io
SMTP_FROM_NAME=CyberVerse

# ============================================================================
# AI/LLM CONFIGURATION (اختياري - يتم ملأه لاحقاً)
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================================
# PAYMENT CONFIGURATION (Stripe/PayPal - اختياري)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ============================================================================
# OAUTH CONFIGURATION (Google, GitHub, Microsoft)
# ============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# ============================================================================
# FILE STORAGE CONFIGURATION (S3/R2)
# ============================================================================
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cyberverse-uploads
AWS_S3_REGION=us-east-1

# Cloudflare R2 (Alternative)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/cyberverse.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL=10/s
RATE_LIMIT_AUTH=5/m
RATE_LIMIT_API=30/s

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
BCRYPT_ROUNDS=12
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REGISTRATION=true
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_OAUTH=true
ENABLE_AI_MENTOR=true
ENABLE_CYBER_NEWS=true
ENABLE_CTF_CHALLENGES=true
ENABLE_LABS=true

# ============================================================================
# ANALYTICS & MONITORING (اختياري)
# ============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
MIXPANEL_TOKEN=

# ============================================================================
# DOMAIN & URL CONFIGURATION
# ============================================================================
DOMAIN=localhost
MAIN_URL=http://localhost:3000
API_URL=http://localhost:8000

# ============================================================================
# PHONE VERIFICATION (اختياري - Twilio)
# ============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
ADMIN_EMAIL=admin@cyberverse.io
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ============================================================================
# LANGUAGE & LOCALIZATION
# ============================================================================
SUPPORTED_LANGUAGES=en,ar
DEFAULT_LANGUAGE=en
TIMEZONE=UTC

# ============================================================================
# VERSION
# ============================================================================
APP_VERSION=1.0.0-alpha
BUILD_DATE=2026-07-20
